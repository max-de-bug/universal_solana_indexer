# === Solana RPC ===
# Comma-separated list of RPC URLs for multi-node failover
RPC_URLS=https://api.mainnet-beta.solana.com
WSS_URL=wss://api.mainnet-beta.solana.com

# === Database ===
DATABASE_URL=postgres://indexer:indexer@localhost:5432/solana_indexer

# === Program ===
PROGRAM_ID=YourProgramPublicKeyHere
IDL_PATH=./idl.json
# IDL_ACCOUNT=YourIdlAccountPubkey

# === Indexing Mode ===
# Options: "realtime" (default), "batch", "batch_signatures"
INDEXING_MODE=realtime

# Batch mode settings (only used when INDEXING_MODE=batch)
# BATCH_START_SLOT=0
# BATCH_END_SLOT=100000

# Batch signatures mode (only used when INDEXING_MODE=batch_signatures)
# BATCH_SIGNATURES=sig1,sig2,sig3

# === API ===
API_PORT=3000

# === Tuning ===
BATCH_SIZE=100
BATCH_CONCURRENCY=5
MAX_RETRIES=5
INITIAL_RETRY_DELAY_MS=500
POLL_INTERVAL_MS=2000

# === Database Pool ===
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# === Logging ===
RUST_LOG=universal_solana_indexer=info,sqlx=warn
